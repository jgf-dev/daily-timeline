#!/usr/bin/env bash
set -euo pipefail

run_if_defined() {
  local script="$1"

  if [ "$(npm pkg get "scripts.${script}" 2>/dev/null)" != "{}" ]; then
    echo "pre-commit: ${script}"
    npm run "${script}"
  else
    echo "pre-commit: ${script} (skipped: script not defined in root package.json)"
  fi
}

run_if_defined lint
run_if_defined test
run_if_defined build
