# Shared environment configuration
NODE_ENV=development
LOG_LEVEL=info

# API service
PORT=4000
API_BASE_URL=http://localhost:4000
JWT_SECRET=replace-with-long-random-secret

# Storage providers
STORAGE_PROVIDER=s3
S3_BUCKET=daily-timeline-dev
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Transcription providers
TRANSCRIPTION_PROVIDER=openai
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# Search / retrieval providers
SEARCH_PROVIDER=none
TAVILY_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=

# Screenshot enrichment
SCREENSHOT_OCR_PROVIDER=openai
SCREENSHOT_VISION_MODEL=gpt-4.1-mini
