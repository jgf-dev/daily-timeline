NODE_ENV=development
PORT=3000
DATABASE_PATH=./data/daily-timeline.db

# Provider secrets (set locally, never commit real values)
TRANSCRIPTION_API_KEY=your_transcription_api_key
VOICE_CHAT_API_KEY=your_voice_chat_api_key
SCREENSHOT_ANALYSIS_API_KEY=your_screenshot_analysis_api_key
IMAGE_GENERATION_API_KEY=your_image_generation_api_key

# Model selections
TRANSCRIPTION_MODEL=whisper-1
VOICE_CHAT_MODEL=gpt-realtime
SCREENSHOT_MODEL=gpt-4.1-mini
IMAGE_MODEL=gpt-image-1
