{
  "name": "daily-timeline",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for Daily Timeline product",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @daily-timeline/web",
    "dev:web": "npm run dev --workspace @daily-timeline/web",
    "dev:api": "npm run dev --workspace @daily-timeline/api",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.58.0",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.5.3"
  },
  "dependencies": {
    "jiti": "^2.6.1"
  }
}
